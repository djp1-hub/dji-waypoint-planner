# Mapy.cz API key for geocoding (address search)
# https://developer.mapy.cz — vytvořit účet a klíč v sekci "Moje aplikace"
NEXT_PUBLIC_MAPY_API_KEY=your_mapy_api_key_here

# Cesium ion access token — https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_TOKEN=your_cesium_ion_token_here

# Google Maps API key with Map Tiles API enabled
# https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAIP API key — https://www.openaip.net/
# Client-side tile layer (NEXT_PUBLIC_ needed — key is embedded in tile URLs, not a secret)
NEXT_PUBLIC_OPENAIP_API_KEY=your_openaip_api_key_here
